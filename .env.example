# PostgreSQL — Railway managed DB connection string
DATABASE_URL=postgres://user:password@localhost:5432/vertualeventlive?sslmode=disable

# Redis — Upstash Redis URL (redis:// or rediss:// for TLS)
REDIS_URL=redis://localhost:6379

# JWT — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Server
PORT=8080
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# WiPay — Caribbean payout rail (host payout gateway, alternative to Stripe Connect).
# WIPAY_API_BASE_URL must point at WiPay's confirmed disbursement endpoint —
# leave blank to keep WiPay payouts queued as "pending" instead of firing blind.
WIPAY_API_BASE_URL=
WIPAY_API_KEY=
WIPAY_ENVIRONMENT=sandbox

# PayPal — Payouts API (host payout gateway, alternative to Stripe Connect).
# https://developer.paypal.com/dashboard/applications for client id/secret.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox

# Platform commission for Package B (default: 15)
COMMISSION_PERCENT=15
